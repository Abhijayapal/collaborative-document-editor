# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB Atlas connection string
# NOTE: URL-encode special chars in password e.g. ( → %28, ) → %29
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>

# Single port for REST API, Socket.IO, and Yjs WebSocket
PORT=5000

# Strong random secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Frontend origin — used to restrict CORS (no trailing slash)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

REDIS_HOST=localhost
REDIS_PORT=6379
